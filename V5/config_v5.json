{
  "experiment": "V5 DINOv2 LoRA",
  "use_lora": true,
  "dinov2_model": "facebook/dinov2-base",
  "train_metadata": "dataset/train2_metadata.csv",
  "test_metadata": "dataset/test2_metadata.csv",
  "model_dir": "models/dinov2_lora",
  "embedding_dir": "embeddings/dinov2_lora",
  "results_dir": "V5/results",
  "projection_dim": 256,
  "batch_size": 128,
  "epochs": 120,
  "learning_rate": 0.0005,
  "weight_decay": 0.001,
  "temperature": 0.07,
  "train_split": 0.8,
  "seed": 42,
  "scheduler": "none",
  "lora": {
    "r": 8,
    "alpha": 16,
    "dropout": 0.05,
    "target_modules": ["query", "value"]
  }
}
